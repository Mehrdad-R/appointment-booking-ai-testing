pipeline {
    agent any

    environment {
        PYTHON_EXE = 'C:\\Users\\mrakh\\AppData\\Local\\Programs\\Python\\Python310\\python.exe'
        GEMINI_API_KEY = credentials('gemini-api-key')
        GEMINI_MODEL = 'gemini-2.5-flash-lite'
    }

    stages {
        stage('Check Python') {
            steps {
                bat '"%PYTHON_EXE%" --version'
            }
        }

        stage('Setup Python Environment') {
            steps {
                bat '"%PYTHON_EXE%" -m venv venv'
                bat 'venv\\Scripts\\python -m pip install -r backend\\requirements.txt'
            }
        }

        stage('Generate AI Test Plan') {
            steps {
                bat '''
                    venv\\Scripts\\python -c "import subprocess, json; files=subprocess.check_output(['git','show','--pretty=','--name-only','HEAD'], text=True).splitlines(); files=[f for f in files if f.strip()]; open(r'backend\\agent\\changed_files.json','w',encoding='utf-8').write(json.dumps(files, indent=2))"
                    echo Changed files:
                    type backend\\agent\\changed_files.json

                    venv\\Scripts\\python backend\\agent\\generate_test_plan.py

                    echo Generated AI test plan:
                    type backend\\agent\\test_plan.json
                '''
            }
        }

        stage('Write Agent Decision Summary') {
            steps {
                bat '''
                    venv\\Scripts\\python backend\\agent\\write_decision_summary.py
                    echo Agent decision summary:
                    type backend\\agent\\agent_decision_summary.md
                '''
            }
        }

        stage('Execute AI Test Plan') {
            steps {
                bat '''
                    venv\\Scripts\\python -c "import json; plan=json.load(open(r'backend\\agent\\test_plan.json', encoding='utf-8')); print(' or '.join(plan['selected_groups']))" > marker_expression.txt
                    set /p MARKER=<marker_expression.txt
                    echo Running pytest with marker expression: %MARKER%
                    venv\\Scripts\\python -m pytest -m "%MARKER%" backend/tests --junitxml=agent-report.xml
                '''
            }
        }

        stage('Publish Test Results') {
            steps {
                junit allowEmptyResults: true, testResults: 'agent-report.xml'
            }
        }

        stage('Update Runtime History') {
            steps {
                bat '''
                    venv\\Scripts\\python backend\\agent\\update_history_summary.py
                    echo Updated runtime history:
                    type backend\\agent\\history_runtime.json
                '''
            }
        }

        stage('Sync Agent Snapshot to Database') {
            steps {
                bat '''
                    venv\\Scripts\\python backend\\agent\\sync_agent_snapshot_to_db.py
                '''
            }
        }

        stage('Archive Agent Artifacts') {
            steps {
                archiveArtifacts artifacts: 'backend/agent/changed_files.json,backend/agent/test_plan.json,backend/agent/history_runtime.json,backend/agent/agent_decision_summary.md,agent-report.xml', fingerprint: true
            }
        }
    }
}